# Minecraft Bedrock Server Files
# Não versionar arquivos binários do servidor
servidor/bedrock_server
servidor/bedrock_server.exe
servidor/bedrock_server.pdb
servidor/*.so
servidor/*.dll
servidor/*.dylib

# Diretório de mundos
servidor/worlds/
servidor/world*/

# Logs
*.log
logs/

# Backups
*.bak
*.backup

# Arquivos temporários
*.tmp
*.temp

# Node modules
node_modules/

# Docker
.dockerignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# Mac
.DS_Store

# Manter apenas server.properties na pasta servidor
!servidor/server.properties
